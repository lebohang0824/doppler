---
import { db, Issue, eq, count } from 'astro:db';

const { projectId } = Astro.props;

const initialCounts = {
  todo: 0,
  queued: 0,
  executing: 0,
  testing: 0,
  done: 0,
};

if (projectId) {
  try {
    const results = await db
      .select({ status: Issue.status, count: count() })
      .from(Issue)
      .where(eq(Issue.project_id, projectId))
      .groupBy(Issue.status);

    results.forEach((row) => {
      const status = row.status.toLowerCase();
      if (initialCounts.hasOwnProperty(status)) {
        initialCounts[status] = row.count;
      }
    });
  } catch (e) {
    console.error("Error fetching initial counts:", e);
  }
}

const currentPath = Astro.url.pathname;
const projectQuery = projectId ? `?project_id=${projectId}` : '';
---

<aside class="sidebar" x-data={`sidebar({ projectId: '${projectId || ''}', initialCounts: ${JSON.stringify(initialCounts)} })`}>
  <div class="logo">
    <i class="fa-solid fa-satellite-dish fa-xl"></i>
    <h2>Doppler</h2>
  </div>
  
  <nav>
    <div class="nav-section">
      <h3>Menu</h3>
      <ul>
        <li>
          <a href={`/${projectQuery}`} class={currentPath === '/' ? 'active' : ''}>
            <i class="fa-solid fa-gauge-high icon"></i> Dashboard
          </a>
        </li>
        <li>
          <a href={`/projects${projectQuery}`} class={currentPath.startsWith('/projects') ? 'active' : ''}>
            <i class="fa-solid fa-folder-tree icon"></i> Projects
          </a>
        </li>
        <li>
          <a href={`/settings`} class={currentPath.startsWith('/settings') ? 'active' : ''}>
            <i class="fa-solid fa-gear icon"></i> Settings
          </a>
        </li>
      </ul>
    </div>

    <div class="nav-section">
      <h3>Issue Status</h3>
      <ul class="status-list">
        <li>
          <a href={`/issues?status=todo${projectId ? `&project_id=${projectId}` : ''}`} class="status-link">
            <span class="label-group">
                <i class="fa-solid fa-list-check icon"></i>
                <span class="label">Todo</span>
            </span>
            <span class="counter" x-text="counts.todo"></span>
          </a>
        </li>
        <li>
          <a href={`/issues?status=queued${projectId ? `&project_id=${projectId}` : ''}`} class="status-link">
            <span class="label-group">
                <i class="fa-solid fa-clock icon"></i>
                <span class="label">Queued</span>
            </span>
            <span class="counter" x-text="counts.queued"></span>
          </a>
        </li>
        <li>
          <a href={`/issues?status=executing${projectId ? `&project_id=${projectId}` : ''}`} class="status-link">
            <span class="label-group">
                <i class="fa-solid fa-play icon"></i>
                <span class="label">Executing</span>
            </span>
            <span class="counter" x-text="counts.executing"></span>
          </a>
        </li>
        <li>
          <a href={`/issues?status=testing${projectId ? `&project_id=${projectId}` : ''}`} class="status-link">
            <span class="label-group">
                <i class="fa-solid fa-flask icon"></i>
                <span class="label">Testing</span>
            </span>
            <span class="counter" x-text="counts.testing"></span>
          </a>
        </li>
        <li>
          <a href={`/issues?status=done${projectId ? `&project_id=${projectId}` : ''}`} class="status-link">
            <span class="label-group">
                <i class="fa-solid fa-circle-check icon"></i>
                <span class="label">Done</span>
            </span>
            <span class="counter" x-text="counts.done"></span>
          </a>
        </li>
      </ul>
    </div>
  </nav>
</aside>

<script is:inline>
  if (!window.sidebarInitialized) {
    window.sidebarInitialized = true;
    document.addEventListener('alpine:init', () => {
      Alpine.data('sidebar', ({ projectId, initialCounts }) => ({
        projectId,
        counts: initialCounts,
        
        async init() {
          if (!this.projectId) return;
          
          // Poll for updates every 5 seconds
          setInterval(() => {
            this.fetchCounts();
          }, 5000);
        },
        
        async fetchCounts() {
          try {
            const res = await fetch(`/api/projects/${this.projectId}/counts`);
            if (res.ok) {
              const newCounts = await res.json();
              
              // Simple change detection for toasts
              if (newCounts.testing > this.counts.testing) {
                window.notify('A background task has finished execution', 'success', 'fa-circle-check');
              } else if (newCounts.executing > this.counts.executing) {
                window.notify('A background task has started running', 'info', 'fa-play');
              }
              
              this.counts = newCounts;
            }
          } catch (e) {
            console.error('Failed to fetch sidebar counts', e);
          }
        }
      }));
    });
  }
</script>

<style>
  .sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    background-color: var(--sidebar-bg);
    color: var(--sidebar-text);
    display: flex;
    flex-direction: column;
    height: 100vh;
    padding: 1.5rem;
    overflow-y: auto;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    font-size: 1.2rem;
    font-weight: bold;
    color: white;
  }

  .nav-section {
    margin-bottom: 2rem;
  }

  .nav-section h3 {
    text-transform: uppercase;
    font-size: 0.75rem;
    color: var(--accent-color);
    margin-bottom: 1rem;
    letter-spacing: 1px;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li {
    margin-bottom: 0.5rem;
  }

  a {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    color: var(--sidebar-text);
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.2s ease;
    opacity: 0.8;
  }

  a:hover {
    background-color: rgba(149, 204, 191, 0.1);
    color: white;
    opacity: 1;
  }

  a.active {
    background-color: var(--primary-color);
    color: white;
    opacity: 1;
  }

  .icon {
    margin-right: 0.75rem;
    width: 20px;
    text-align: center;
  }

  .label-group {
    display: flex;
    align-items: center;
  }

  .label-group .icon {
    margin-right: 0.75rem;
  }

  .status-list li {
    margin-bottom: 0.25rem;
  }

  .status-link {
    justify-content: space-between;
    padding: 0.5rem 1rem;
    width: 100%;
  }
  
  .status-list li:hover {
     background-color: transparent;
  }

  .counter {
    background-color: rgba(0, 0, 0, 0.2);
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.85rem;
    min-width: 24px;
    text-align: center;
  }
</style>
