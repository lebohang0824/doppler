<div
  class='modal-overlay'
  x-show='modals.cliRequired'
  x-cloak
  style='display: none;'
  x-transition.opacity>
  <div class='modal'>
    <div class='modal-header'>
      <h2><i class='fa-solid fa-terminal'></i> AI CLI Required</h2>
    </div>
    <div class='modal-body'>
      <p class='modal-intro'>
        To use this application, you need to install at least one AI CLI tool.
      </p>

      <div class='cli-options'>
        <div class='cli-option'>
          <div class='cli-icon'>
            <i class='fa-solid fa-robot'></i>
          </div>
          <div class='cli-info'>
            <h3>Gemini CLI</h3>
            <p>Google's AI coding assistant CLI</p>
            <a
              href='https://ai.google.dev/gemini-api/docs/gemini-cli'
              target='_blank'
              class='install-link'>
              <i class='fa-solid fa-arrow-up-right-from-square'></i>
              View Installation Guide
            </a>
          </div>
          <div
            class='cli-status'
            x-show='cliAvailable.gemini'>
            <span class='not-installed'>Not Installed</span>
          </div>
          <div
            class='cli-status'
            x-show='!cliAvailable.gemini'>
            <span class='installed'
              ><i class='fa-solid fa-check'></i> Ready</span
            >
          </div>
        </div>

        <div class='cli-option'>
          <div class='cli-icon'>
            <i class='fa-solid fa-robot'></i>
          </div>
          <div class='cli-info'>
            <h3>Opencode CLI</h3>
            <p>AI coding agent with multi-model support</p>
            <a
              href='https://opencode.ai'
              target='_blank'
              class='install-link'>
              <i class='fa-solid fa-arrow-up-right-from-square'></i>
              View Installation Guide
            </a>
          </div>
          <div
            class='cli-status'
            x-show='cliAvailable.opencode'>
            <span class='not-installed'>Not Installed</span>
          </div>
          <div
            class='cli-status'
            x-show='!cliAvailable.opencode'>
            <span class='installed'
              ><i class='fa-solid fa-check'></i> Ready</span
            >
          </div>
        </div>
      </div>

      <p class='modal-note'>
        <i class='fa-solid fa-info-circle'></i>
        After installing, refresh the page to continue.
      </p>
    </div>
  </div>
</div>

