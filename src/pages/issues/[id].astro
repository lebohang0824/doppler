---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, Issue, Project, eq } from 'astro:db';

const { id } = Astro.params;

if (!id) {
    return Astro.redirect('/issues');
}

const issueResult = await db.select().from(Issue).where(eq(Issue.id, id));
const issue = issueResult[0];

if (!issue) {
    return Astro.redirect('/issues');
}

const projectResult = await db.select().from(Project).where(eq(Project.id, issue.project_id));
const project = projectResult[0];

const title = `Issue #${id.slice(0, 8)} - ${issue.title}`;
---

<DashboardLayout title={title} projectId={issue.project_id}>
  <div x-data={`issueDetail({ 
    id: '${id}', 
    projectId: '${issue.project_id}', 
    initialStatus: '${issue.status}',
    initialTitle: ${JSON.stringify(issue.title)},
    initialDescription: ${JSON.stringify(issue.description)},
    initialType: '${issue.type}',
    initialPriority: '${issue.priority}',
    initialAttachments: ${JSON.stringify(issue.attachments)},
    initialUpdatedAt: '${issue.updated_at.toISOString()}'
  })`}>
    <div class="header">
        <div class="title-section">
            <a :href="'/issues?project_id=' + projectId" class="btn btn-secondary btn-small">
                <i class="fa-solid fa-arrow-left"></i> Back
            </a>
            <h1 x-text="title"></h1>
        </div>
        <div class="header-actions">
            <!-- Execution Timer -->
            <template x-if="status === 'executing'">
                <div class="execution-timer">
                    <i class="fa-solid fa-stopwatch"></i>
                    <span x-text="elapsedTime"></span>
                </div>
            </template>
            <!-- Edit Button (Todo only) -->
            <template x-if="status === 'todo'">
                <button 
                    @click="openEdit()" 
                    class="btn btn-secondary btn-small"
                    title="Edit Issue">
                    <i class="fa-solid fa-pen-to-square"></i>
                </button>
            </template>

            <!-- Delete Button -->
            <template x-if="status !== 'executing'">
                <button 
                    @click="deleteIssue()" 
                    class="btn btn-danger btn-small"
                    title="Delete Issue">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </template>

            <!-- Testing State Actions -->
            <template x-if="status === 'testing'">
                <div class="action-group">
                    <button @click="modals.approve = true" class="btn btn-success">
                        <i class="fa-solid fa-check"></i> Approve
                    </button>
                    <button @click="modals.reject = true" class="btn btn-danger">
                        <i class="fa-solid fa-xmark"></i> Reject
                    </button>
                </div>
            </template>

            <!-- Execution Actions -->
            <template x-if="status === 'todo' || status === 'queued'">
                <div class="execution-actions">
                    <div class="selected-model-pill" x-show="selectedModel">
                        <i class="fa-solid fa-microchip"></i>
                        <span x-text="selectedModel?.model?.name || selectedModel?.model_id"></span>
                        <a href="/settings" title="Change model"><i class="fa-solid fa-gear"></i></a>
                    </div>
                    <button 
                        @click="executeIssue()" 
                        class="btn btn-primary"
                        :disabled="isExecuting">
                        <i class="fa-solid fa-play"></i>
                        <span>Execute</span>
                    </button>
                </div>
            </template>
            <template x-if="status === 'executing'">
                <button 
                    @click="cancelExecution()" 
                    class="btn btn-danger"
                    :disabled="isCancelling">
                    <i class="fa-solid" :class="isCancelling ? 'fa-spinner fa-spin' : 'fa-stop'"></i>
                    <span x-text="isCancelling ? 'Cancelling...' : 'Cancel'"></span>
                </button>
            </template>
        </div>
    </div>

    <div class="dashboard-content">
        <div class="cards-grid">
            <div class="main-column">
                <!-- Details Card -->
                <div class="card details-card">
                    <div class="card-header">
                        <h2>Issue Details</h2>
                        <span class="status-badge" :class="status" x-text="status"></span>
                    </div>
                    <div class="card-body">
                        <div class="detail-section">
                            <label>Description</label>
                            <p x-text="description"></p>
                        </div>
                        <div class="detail-section" x-show="attachments && attachments.length > 0">
                            <label>Attachments</label>
                            <ul class="attachments-list">
                                <template x-for="file in attachments" :key="file">
                                    <li>
                                        <i class="fa-solid fa-file"></i>
                                        <span x-text="file"></span>
                                    </li>
                                </template>
                            </ul>
                        </div>
                        <div class="meta-grid">
                            <div class="meta-item">
                                <label>Type</label>
                                <span class="type-badge" :class="type.toLowerCase()" x-text="type"></span>
                            </div>
                            <div class="meta-item">
                                <label>Priority</label>
                                <span class="priority" :class="priority" x-text="priority"></span>
                            </div>
                            <div class="meta-item">
                                <label>Project</label>
                                <span>{project?.name}</span>
                            </div>
                            <div class="meta-item">
                                <label>Created</label>
                                <span>{new Date(issue.created_at).toLocaleString()}</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reports Card -->
                <div class="card reports-card">
                    <div class="card-header">
                        <h2>Execution Results</h2>
                    </div>
                    <div class="reports-list">
                        <template x-if="loadingReports">
                            <div class="loading-state">Loading results...</div>
                        </template>
                        <template x-if="!loadingReports && reports.length === 0">
                            <div class="empty-state-small">No results yet.</div>
                        </template>
                        <template x-for="report in reports" :key="report.id">
                            <div class="report-item">
                                <div class="report-header">
                                    <span class="report-date" x-text="new Date(report.created_at).toLocaleString()"></span>
                                </div>
                                <div class="report-files" x-show="parseFiles(report).length > 0">
                                    <label>Files Affected</label>
                                    <ul>
                                        <template x-for="file in parseFiles(report)" :key="file">
                                            <li x-text="file"></li>
                                        </template>
                                    </ul>
                                </div>
                                <div class="report-details" x-text="report.details"></div>
                            </div>
                        </template>
                    </div>
                </div>
            </div>

            <div class="side-column">
                <!-- Logs Card -->
                <div class="card logs-card">
                    <div class="card-header">
                        <h2>Issue History</h2>
                        <button @click="fetchLogs()" class="refresh-btn">
                            <i class="fa-solid fa-rotate-right"></i>
                        </button>
                    </div>
                    <div class="logs-list">
                        <template x-if="loadingLogs">
                            <div class="loading-state">Loading logs...</div>
                        </template>
                        <template x-if="!loadingLogs && logs.length === 0">
                            <div class="empty-state-small">No history found.</div>
                        </template>
                        <template x-for="log in logs" :key="log.id">
                            <div class="log-item">
                                <div class="log-icon">
                                    <i class="fa-solid fa-circle-info"></i>
                                </div>
                                <div class="log-content">
                                    <div class="log-header">
                                        <span class="log-action" x-text="log.action"></span>
                                        <span class="log-date" x-text="new Date(log.created_at).toLocaleTimeString()"></span>
                                    </div>
                                    <div class="log-summary" x-text="log.summary"></div>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Modal -->
    <div class='modal-overlay' x-show='modals.edit' style='display: none;' x-transition.opacity>
      <div class='modal' @click.away='modals.edit = false'>
        <div class='modal-header'>
          <h2>Edit Issue</h2>
          <button @click='modals.edit = false' class='close-btn'><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form @submit.prevent='updateIssue()'>
          <div class='modal-body'>
            <div class='form-group'>
              <label for='editTitle'>Title</label>
              <input type='text' id='editTitle' x-model='editForm.title' required placeholder='Issue title...' />
            </div>
            <div class='form-group'>
              <label for='editDescription'>Description</label>
              <textarea id='editDescription' x-model='editForm.description' required placeholder='Details...'></textarea>
            </div>
            <div class='form-row'>
              <div class='form-group'>
                <label for='editType'>Type</label>
                <select id='editType' x-model='editForm.type'>
                  <option value='Bug'>Bug</option>
                  <option value='Tweak'>Tweak</option>
                  <option value='Enhancement'>Enhancement</option>
                </select>
              </div>
              <div class='form-group'>
                <label for='editPriority'>Priority</label>
                <select id='editPriority' x-model='editForm.priority'>
                  <option value='low'>Low</option>
                  <option value='medium'>Medium</option>
                  <option value='high'>High</option>
                  <option value='critical'>Critical</option>
                </select>
              </div>
            </div>
          </div>
          <div class='modal-actions'>
            <button type='button' @click='modals.edit = false' class='btn btn-secondary'>Cancel</button>
            <button type='submit' class='btn btn-primary' :disabled='submitting'>
              <i class="fa-solid fa-floppy-disk"></i> Save Changes
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Approve Modal -->
    <div class='modal-overlay' x-show='modals.approve' style='display: none;' x-transition.opacity>
      <div class='modal' @click.away='modals.approve = false'>
        <div class='modal-header'>
          <h2>Approve & Commit</h2>
          <button @click='modals.approve = false' class='close-btn'><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form @submit.prevent='approveIssue()'>
          <div class='modal-body'>
            <div class='form-group'>
              <label for='approveMessage'>Commit Message</label>
              <textarea id='approveMessage' x-model='approvalMessage' required placeholder='Describe what was fixed...'></textarea>
            </div>
          </div>
          <div class='modal-actions'>
            <button type='button' @click='modals.approve = false' class='btn btn-secondary'>Cancel</button>
            <button type='submit' class='btn btn-success' :disabled='submitting'>
              <i class="fa-solid fa-check"></i> Approve
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Reject Modal -->
    <div class='modal-overlay' x-show='modals.reject' style='display: none;' x-transition.opacity>
      <div class='modal' @click.away='modals.reject = false'>
        <div class='modal-header'>
          <h2>Reject Changes</h2>
          <button @click='modals.reject = false' class='close-btn'><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form @submit.prevent='rejectIssue()'>
          <div class='modal-body'>
            <div class='form-group'>
              <label for='rejectReason'>Rejection Reason</label>
              <textarea id='rejectReason' x-model='rejectionReason' required placeholder='Why are these changes being rejected?'></textarea>
            </div>
          </div>
          <div class='modal-actions'>
            <button type='button' @click='modals.reject = false' class='btn btn-secondary'>Cancel</button>
            <button type='submit' class='btn btn-danger' :disabled='submitting'>
              <i class="fa-solid fa-xmark"></i> Reject
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Delete Modal -->
    <div class='modal-overlay' x-show='modals.delete' style='display: none;' x-transition.opacity>
        <div class='modal' @click.away='modals.delete = false'>
            <div class='modal-header'>
                <h2>Delete Issue</h2>
                <button @click='modals.delete = false' class='close-btn'><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class='modal-body'>
                <p>Are you sure you want to delete this issue? This action cannot be undone.</p>
            </div>
            <div class='modal-actions'>
                <button type='button' @click='modals.delete = false' class='btn btn-secondary'>Cancel</button>
                <button type='button' @click='confirmDelete' class='btn btn-danger' :disabled='submitting'>
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
  </div>
</DashboardLayout>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('issueDetail', ({ id, projectId, initialStatus, initialTitle, initialDescription, initialType, initialPriority, initialAttachments, initialUpdatedAt }) => ({
      id,
      projectId,
      status: initialStatus || '',
      title: initialTitle,
      description: initialDescription,
      type: initialType,
      priority: initialPriority,
      attachments: initialAttachments || [],
      updatedAt: initialUpdatedAt ? new Date(initialUpdatedAt) : new Date(),
      elapsedTime: '0s',
      isExecuting: false,
      isCancelling: false,
      submitting: false,
      logs: [],
      reports: [],
      loadingLogs: true,
      loadingReports: true,
      selectedModel: null,
      
      modals: {
        approve: false,
        reject: false,
        delete: false,
        edit: false,
      },
      approvalMessage: '',
      rejectionReason: '',
      editForm: {
        title: '',
        description: '',
        type: '',
        priority: ''
      },
      
      async init() {
        this.loadSelectedModel();
        await this.fetchStatus();
        await this.fetchLogs();
        await this.fetchReports();
        
        // Timer for elapsed time
        setInterval(() => {
          if (this.status === 'executing' && this.updatedAt) {
            const diff = Math.floor((new Date() - new Date(this.updatedAt)) / 1000);
            if (diff < 60) {
              this.elapsedTime = `${diff}s`;
            } else if (diff < 3600) {
              const mins = Math.floor(diff / 60);
              const secs = diff % 60;
              this.elapsedTime = `${mins}m ${secs}s`;
            } else {
              const hours = Math.floor(diff / 3600);
              const mins = Math.floor((diff % 3600) / 60);
              this.elapsedTime = `${hours}h ${mins}m`;
            }
          }
        }, 1000);

        // Auto refresh if executing
        setInterval(() => {
            this.fetchStatus();
            if (this.status === 'executing' || this.status === 'queued') {
                this.fetchLogs();
                this.fetchReports();
            }
        }, 3000);
      },

      async loadSelectedModel() {
        try {
          const localModel = localStorage.getItem('selectedModel');
          if (localModel) {
            this.selectedModel = JSON.parse(localModel);
          }

          const res = await fetch('/api/settings/selected');
          if (res.ok) {
            const data = await res.json();
            this.selectedModel = data;
            localStorage.setItem('selectedModel', JSON.stringify(data));
          }
        } catch (e) {
          console.error('Failed to load selected model:', e);
        }
      },
      
      async fetchStatus() {
        try {
            const res = await fetch(`/api/issues/${this.id}`);
            if (res.ok) {
                const data = await res.json();
                if (this.status === 'executing' && data.status === 'testing') {
                    window.notify('Execution completed! Move to testing.', 'success', 'fa-circle-check');
                } else if (this.status === 'queued' && data.status === 'executing') {
                    window.notify('Execution started!', 'info', 'fa-play');
                }
                
                // Update updatedAt if status changed
                if (this.status !== data.status) {
                    this.updatedAt = data.updated_at;
                }
                
                this.status = data.status;
                // Update other fields too in case they changed elsewhere
                this.title = data.title;
                this.description = data.description;
                this.type = data.type;
                this.priority = data.priority;
                this.attachments = data.attachments || [];
            }
        } catch (e) {
            console.error('Failed to fetch status', e);
        }
      },
      
      openEdit() {
        this.editForm = {
            title: this.title,
            description: this.description,
            type: this.type,
            priority: this.priority
        };
        this.modals.edit = true;
      },

      async updateIssue() {
        this.submitting = true;
        try {
            const res = await fetch(`/api/issues/${this.id}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(this.editForm)
            });
            if (res.ok) {
                const updated = await res.json();
                this.title = updated.title;
                this.description = updated.description;
                this.type = updated.type;
                this.priority = updated.priority;
                window.notify('Issue updated successfully', 'success', 'fa-circle-check');
                this.modals.edit = false;
                await this.fetchLogs();
            } else {
                const data = await res.json();
                window.notify(data.error || 'Update failed', 'error', 'fa-circle-exclamation');
            }
        } catch (e) {
            console.error('Update error', e);
            window.notify('An error occurred', 'error', 'fa-circle-exclamation');
        } finally {
            this.submitting = false;
        }
      },
      
      async fetchLogs() {
        this.loadingLogs = true;
        try {
            const res = await fetch(`/api/issues/${this.id}/logs`);
            if (res.ok) {
                this.logs = await res.json();
            }
        } finally {
            this.loadingLogs = false;
        }
      },

      async fetchReports() {
        this.loadingReports = true;
        try {
            const res = await fetch(`/api/issues/${this.id}/reports`);
            if (res.ok) {
                this.reports = await res.json();
            }
        } finally {
            this.loadingReports = false;
        }
      },

      parseFiles(report) {
        if (!report.files_changed) return [];
        if (Array.isArray(report.files_changed)) return report.files_changed;
        try {
            return JSON.parse(report.files_changed);
        } catch (e) {
            console.error('Failed to parse files_changed', e);
            return [];
        }
      },
      
      async executeIssue() {
        this.isExecuting = true;
        try {
            const res = await fetch(`/api/issues/${this.id}/execute`, { method: 'POST' });
            if (res.ok) {
                const data = await res.json();
                this.status = data.status;
                window.notify(this.status === 'queued' ? 'Task added to queue' : 'Execution started', 'info', this.status === 'queued' ? 'fa-clock' : 'fa-play');
                this.fetchLogs();
            } else {
                window.notify('Failed to start execution', 'error', 'fa-circle-exclamation');
            }
        } catch (e) {
            console.error('Execution error', e);
            window.notify('An error occurred', 'error', 'fa-circle-exclamation');
        } finally {
            this.isExecuting = false;
        }
      },

      async cancelExecution() {
        this.isCancelling = true;
        try {
            const res = await fetch(`/api/issues/${this.id}/cancel`, { method: 'POST' });
            if (res.ok) {
                const data = await res.json();
                this.status = data.status;
                window.notify('Execution cancelled', 'info', 'fa-stop');
                this.fetchLogs();
            } else {
                const data = await res.json();
                window.notify(data.error || 'Failed to cancel execution', 'error', 'fa-circle-exclamation');
            }
        } catch (e) {
            console.error('Cancel error', e);
            window.notify('An error occurred', 'error', 'fa-circle-exclamation');
        } finally {
            this.isCancelling = false;
        }
      },

      async approveIssue() {
        this.submitting = true;
        try {
            const res = await fetch(`/api/issues/${this.id}/approve`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: this.approvalMessage })
            });
            if (res.ok) {
                window.notify('Issue approved and committed', 'success', 'fa-circle-check');
                this.modals.approve = false;
                this.approvalMessage = '';
                await this.fetchStatus();
                await this.fetchLogs();
            } else {
                const data = await res.json();
                window.notify(data.error || 'Approval failed', 'error', 'fa-circle-exclamation');
            }
        } finally {
            this.submitting = false;
        }
      },

      async rejectIssue() {
        this.submitting = true;
        try {
            const res = await fetch(`/api/issues/${this.id}/reject`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason: this.rejectionReason })
            });
            if (res.ok) {
                window.notify('Issue rejected and reverted', 'warning', 'fa-circle-xmark');
                this.modals.reject = false;
                this.rejectionReason = '';
                await this.fetchStatus();
                await this.fetchLogs();
            } else {
                const data = await res.json();
                window.notify(data.error || 'Rejection failed', 'error', 'fa-circle-exclamation');
            }
        } finally {
            this.submitting = false;
        }
      },

      deleteIssue() {
        this.modals.delete = true;
      },

      async confirmDelete() {
        this.submitting = true;
        try {
            const res = await fetch(`/api/issues/${this.id}`, { method: 'DELETE' });
            if (res.ok) {
                window.notify('Issue deleted', 'success', 'fa-trash-can');
                setTimeout(() => {
                    window.location.href = `/issues?project_id=${this.projectId}`;
                }, 1000);
            } else {
                window.notify('Failed to delete issue', 'error', 'fa-circle-exclamation');
            }
        } catch (e) {
            console.error('Delete error', e);
            window.notify('An error occurred', 'error', 'fa-circle-exclamation');
        } finally {
            this.submitting = false;
            this.modals.delete = false;
        }
      }
    }));
  });
</script>

<style>
  .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
  }
  
  .title-section {
      display: flex;
      align-items: center;
      gap: 1.5rem;
  }

  .title-section h1 {
      margin: 0;
      font-size: 1.5rem;
  }

  .header-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
  }

  .action-group {
      display: flex;
      gap: 0.75rem;
  }

  .execution-timer {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.35rem 0.75rem;
      background: #fffbeb;
      border: 1px solid #fef3c7;
      border-radius: 6px;
      font-size: 0.85rem;
      color: #d97706;
      font-weight: 600;
      font-family: monospace;
  }

  .execution-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
  }

  .selected-model-pill {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.35rem 0.75rem;
      background: #f1f5f9;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      font-size: 0.8rem;
      color: var(--accent-color);
  }

  .selected-model-pill i {
      font-size: 0.75rem;
  }

  .selected-model-pill a {
      color: var(--accent-color);
      margin-left: 0.25rem;
      transition: color 0.2s;
  }

  .selected-model-pill a:hover {
      color: var(--primary-color);
  }

  .status-running {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--primary-color);
      font-weight: bold;
  }

  .cards-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 1.5rem;
  }

  .card-body {
      padding: 1.5rem;
  }

  .detail-section {
      margin-bottom: 1.5rem;
  }

  .detail-section label {
      display: block;
      font-size: 0.8rem;
      text-transform: uppercase;
      color: var(--accent-color);
      margin-bottom: 0.5rem;
      font-weight: bold;
  }

  .attachments-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
  }

  .attachments-list li {
      background: #f8f9fa;
      padding: 0.5rem 0.75rem;
      border-radius: 4px;
      border: 1px solid var(--border-color);
      font-size: 0.85rem;
      display: flex;
      align-items: center;
