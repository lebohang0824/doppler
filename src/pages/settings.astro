---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import ModelConfigCard from '../components/settings/ModelConfigCard.astro';

// Read project_id from search params on the server-side
const currentProjectId = Astro.url.searchParams.get('project_id');
---

<DashboardLayout
  title='Settings'
  projectId={currentProjectId}>
  <div x-data='settingsPage()'>
    <div class='header'>
      <h1>Settings</h1>
    </div>

    <div class='settings-content'>
      <ModelConfigCard />
    </div>
  </div>
</DashboardLayout>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('settingsPage', () => ({
      modelStatusList: [],
      loadingModels: true,
      selectedModelId: '',

      init() {
        this.loadSelectedModel();
        this.loadModels();
      },

      async loadSelectedModel() {
        try {
          // Try localStorage first as per requirement
          const localModel = localStorage.getItem('selectedModel');
          if (localModel) {
            const parsed = JSON.parse(localModel);
            this.selectedModelId = parsed.model_id;
          }

          const res = await fetch('/api/settings/selected');
          if (res.ok) {
            const data = await res.json();
            this.selectedModelId = data.model_id;
            localStorage.setItem('selectedModel', JSON.stringify(data));
          }
        } catch (e) {
          console.error('Failed to load selected model:', e);
        }
      },

      async selectModel(model) {
        try {
          const res = await fetch('/api/settings/selected', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              provider: model.provider,
              model_id: model.id,
            }),
          });

          if (res.ok) {
            const data = await res.json();
            this.selectedModelId = data.model_id;
            localStorage.setItem('selectedModel', JSON.stringify(data));
            window.notify(
              `Model ${model.name} selected`,
              'success',
              'fa-check-circle',
            );
          } else {
            window.notify(
              'Failed to select model',
              'error',
              'fa-circle-exclamation',
            );
          }
        } catch (e) {
          console.error('Failed to select model:', e);
          window.notify(
            'Failed to select model',
            'error',
            'fa-circle-exclamation',
          );
        }
      },

      async loadModels() {
        this.loadingModels = true;
        try {
          const res = await fetch('/api/settings/models');
          if (res.ok) {
            this.modelStatusList = await res.json();
          }
        } catch (e) {
          console.error('Failed to load models:', e);
        } finally {
          this.loadingModels = false;
        }
      },

      async refreshModels() {
        await this.loadModels();
      },
    }));
  });
</script>

<style>
  .header {
    margin-bottom: 2rem;
  }

  .header h1 {
    margin: 0;
    color: var(--text-color);
  }

  .settings-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
</style>
