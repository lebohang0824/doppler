---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import TokenConfigCard from '../components/settings/TokenConfigCard.astro';
import ModelConfigCard from '../components/settings/ModelConfigCard.astro';

// Read project_id from search params on the server-side
const currentProjectId = Astro.url.searchParams.get('project_id');
---

<DashboardLayout
  title='Settings'
  projectId={currentProjectId}>
  <div x-data='settingsPage()'>
    <div class='header'>
      <h1>Settings</h1>
    </div>

    <div class='settings-content'>
      <TokenConfigCard />
      <ModelConfigCard />
    </div>
  </div>
</DashboardLayout>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('settingsPage', () => ({
      providerConfigs: [
        {
          id: 'anthropic',
          name: 'Anthropic (Claude)',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://console.anthropic.com/settings/keys',
        },
        {
          id: 'openai',
          name: 'OpenAI',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://platform.openai.com/api-keys',
        },
        {
          id: 'google',
          name: 'Google AI (Gemini)',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://aistudio.google.com/app/apikey',
        },
        {
          id: 'x-ai',
          name: 'xAI (Grok)',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://console.x.ai',
        },
        {
          id: 'cohere',
          name: 'Cohere',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://dashboard.cohere.com/api-keys',
        },
        {
          id: 'mistral',
          name: 'Mistral AI',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://console.mistral.ai/api-keys/',
        },
        {
          id: 'amazon',
          name: 'Amazon Bedrock',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Configure AWS credentials via AWS CLI or environment variables',
        },
        {
          id: 'deepseek',
          name: 'DeepSeek',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://platform.deepseek.com/api_keys',
        },
        {
          id: 'nvidia',
          name: 'NVIDIA',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://ngc.nvidia.com/setup/api-key',
        },
        {
          id: 'nebius',
          name: 'Nebius',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://nebius.ai/studio/settings/api-keys',
        },
        {
          id: 'qwen',
          name: 'Qwen (阿里云)',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from DashScope or use local Ollama models',
        },
        {
          id: 'minimax',
          name: 'MiniMax',
          token: '',
          hasToken: false,
          showToken: false,
          hint: 'Get your API key from https://platform.minimaxi.com/',
        },
      ],
      modelStatusList: [],
      loadingModels: true,
      selectedModelId: '',

      init() {
        this.loadTokens();
        this.loadSelectedModel();
        this.loadModels();
      },

      async loadTokens() {
        try {
          const res = await fetch('/api/settings/tokens');
          if (res.ok) {
            const tokens = await res.json();
            this.providerConfigs.forEach((provider) => {
              if (tokens[provider.id]) {
                provider.hasToken = tokens[provider.id].hasToken;
              }
            });
          }
        } catch (e) {
          console.error('Failed to load tokens:', e);
        }
      },

      async loadSelectedModel() {
        try {
          // Try localStorage first as per requirement
          const localModel = localStorage.getItem('selectedModel');
          if (localModel) {
            const parsed = JSON.parse(localModel);
            this.selectedModelId = parsed.model_id;
          }

          const res = await fetch('/api/settings/selected');
          if (res.ok) {
            const data = await res.json();
            this.selectedModelId = data.model_id;
            localStorage.setItem('selectedModel', JSON.stringify(data));
          }
        } catch (e) {
          console.error('Failed to load selected model:', e);
        }
      },

      async selectModel(model) {
        if (!model.configured && model.tier === 'paid') {
          window.notify(
            'Please configure API token for this provider first',
            'error',
            'fa-key',
          );
          return;
        }

        try {
          const res = await fetch('/api/settings/selected', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              provider: model.provider,
              model_id: model.id,
            }),
          });

          if (res.ok) {
            const data = await res.json();
            this.selectedModelId = data.model_id;
            localStorage.setItem('selectedModel', JSON.stringify(data));
            window.notify(
              `Model ${model.name} selected`,
              'success',
              'fa-check-circle',
            );
          } else {
            window.notify(
              'Failed to select model',
              'error',
              'fa-circle-exclamation',
            );
          }
        } catch (e) {
          console.error('Failed to select model:', e);
          window.notify(
            'Failed to select model',
            'error',
            'fa-circle-exclamation',
          );
        }
      },

      async loadModels() {
        this.loadingModels = true;
        try {
          const res = await fetch('/api/settings/models');
          if (res.ok) {
            this.modelStatusList = await res.json();
          }
        } catch (e) {
          console.error('Failed to load models:', e);
        } finally {
          this.loadingModels = false;
        }
      },

      async refreshModels() {
        await this.loadTokens();
        await this.loadModels();
      },

      async saveToken(provider) {
        if (!provider.token) return;

        try {
          const res = await fetch('/api/settings/tokens', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              provider: provider.id,
              token: provider.token,
            }),
          });

          if (res.ok) {
            provider.hasToken = true;
            window.notify(`${provider.name} token saved`, 'success', 'fa-key');
            this.loadModels();
          } else {
            window.notify(
              'Failed to save token',
              'error',
              'fa-circle-exclamation',
            );
          }
        } catch (e) {
          console.error('Failed to save token:', e);
          window.notify(
            'Failed to save token',
            'error',
            'fa-circle-exclamation',
          );
        }
      },

      async clearToken(provider) {
        try {
          const res = await fetch(
            `/api/settings/tokens?provider=${provider.id}`,
            {
              method: 'DELETE',
            },
          );

          if (res.ok) {
            provider.token = '';
            provider.hasToken = false;
            window.notify(
              `${provider.name} token cleared`,
              'warning',
              'fa-key',
            );
            this.loadModels();
          } else {
            window.notify(
              'Failed to clear token',
              'error',
              'fa-circle-exclamation',
            );
          }
        } catch (e) {
          console.error('Failed to clear token:', e);
          window.notify(
            'Failed to clear token',
            'error',
            'fa-circle-exclamation',
          );
        }
      },
    }));
  });
</script>

<style>
  .header {
    margin-bottom: 2rem;
  }

  .header h1 {
    margin: 0;
    color: var(--text-color);
  }

  .settings-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
</style>
